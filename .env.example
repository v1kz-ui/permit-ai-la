# Database
DATABASE_URL=postgresql+asyncpg://permitai:permitai@localhost:5432/permitai
DATABASE_URL_SYNC=postgresql://permitai:permitai@localhost:5432/permitai

# Redis
REDIS_URL=redis://localhost:6379/0

# Data Sources
SOCRATA_APP_TOKEN=
SOCRATA_DATASET_ID=hbkd-qubn

# AI
ANTHROPIC_API_KEY=

# AWS
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_DOCUMENTS=permitai-documents-dev
S3_BUCKET_DEAD_LETTERS=permitai-dead-letters-dev

# Auth (Angeleno OAuth)
ANGELENO_OAUTH_CLIENT_ID=
ANGELENO_OAUTH_CLIENT_SECRET=
ANGELENO_OAUTH_JWKS_URL=
ANGELENO_OAUTH_ISSUER=
MOCK_AUTH=true

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Monitoring
SENTRY_DSN=

# Dashboard (Next.js public env vars — prefix NEXT_PUBLIC_ required)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAPBOX_TOKEN=

# App
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
