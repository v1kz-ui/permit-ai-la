{
  "rule_id": "eo8_expanded",
  "name": "Executive Order 8 - Expanded Rebuild",
  "version": "1.0.0",
  "effective_date": "2025-02-15",
  "description": "Allows rebuilding with expanded scope beyond original structure, with additional review requirements",
  "eligibility": {
    "conditions": [
      {"field": "fire_destroyed", "operator": "eq", "value": true},
      {"field": "declared_disaster_area", "operator": "eq", "value": true}
    ],
    "constraints": {
      "max_sqft_increase_pct": 50,
      "same_footprint": false,
      "same_use_type": true,
      "max_stories": "zoning_allowed",
      "max_height_ft": "zoning_allowed"
    }
  },
  "exemptions": [
    "full_environmental_review"
  ],
  "still_required": [
    "building_permit",
    "zoning_clearance",
    "fire_life_safety",
    "sewer_connection",
    "water_service",
    "lid_compliance",
    "plan_check_standard"
  ],
  "conditional_requirements": [
    {"condition": "is_coastal_zone", "requires": "coastal_development_permit"},
    {"condition": "is_hillside", "requires": "grading_permit"},
    {"condition": "is_hillside", "requires": "geotechnical_review"},
    {"condition": "is_very_high_fire_severity", "requires": "brush_clearance"},
    {"condition": "is_very_high_fire_severity", "requires": "fire_flow"},
    {"condition": "is_historic", "requires": "hpoz_review"},
    {"condition": "has_specific_plan", "requires": "specific_plan_compliance"},
    {"condition": "sqft_increase_gt_20pct", "requires": "design_review"}
  ],
  "estimated_timeline_days": {
    "standard": 90,
    "with_coastal": 150,
    "with_hillside": 120,
    "with_both": 180
  }
}
